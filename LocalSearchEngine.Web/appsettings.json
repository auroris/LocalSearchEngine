{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SearchSettings": {
    "CandidatePoolSize": 500,
    "MinSimilarity": 0.4,
    "ExactPhraseBoost": 0.5,
    "AndTermsBoost": 0.25,
    "HeadingBoost": 0.3,
    "TitleBoost": 0.35,
    "FilenameBoost": 0.4,
    "TermInTextBoost": 0.2
  }
}
