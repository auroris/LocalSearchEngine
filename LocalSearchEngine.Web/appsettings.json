{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "db": "search.db",
  "SearchSettings": {
    "CandidatePoolSize": 500,
    "MaxDistance": 0.6,
    "ExactPhraseBoost": 0.5,
    "AndTermsBoost": 0.25,
    "HeadingBoost": 0.3,
    "TitleBoost": 0.35,
    "FilenameBoost": 0.4,
    "TermInTextBoost": 0.2
  }
}
